# PENTESTGPT configuration
# Copy this file to config/config.yaml and fill in your values.

llm:
  provider: openai          # openai | azure
  model: gpt-4o
  api_key: ""               # or set OPENAI_API_KEY env var
  temperature: 0.2
  max_tokens: 4096

scope:
  targets: []               # list of IPs or CIDR ranges, e.g. ["192.168.1.0/24"]
  excluded: []              # IPs / ranges to never touch

session:
  log_dir: "./logs"
  auto_execute: false       # if true, commands run automatically; false = human confirms
  max_iterations: 50        # safety stop after N reasoning loops
